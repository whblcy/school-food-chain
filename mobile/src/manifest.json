    "title": "学校食材供应链",
    "router": {
      "mode": "hash",
      "base": "./"
    },
    "devServer": {
      "port": 5174,
      "https": false,
      "proxy": {
        "/api": {
          "target": "http://localhost:8000",
          "changeOrigin": true,
