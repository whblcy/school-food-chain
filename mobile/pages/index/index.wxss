.login-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.login-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  width: 80%;
  max-width: 600rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.login-logo {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  color: #1d1d1f;
  margin-bottom: 8rpx;
}

.login-subtitle {
  font-size: 26rpx;
  text-align: center;
  color: #86868b;
  margin-bottom: 48rpx;
}

.login-form {
  margin-bottom: 32rpx;
}

.login-input {
  margin-bottom: 24rpx;
  width: auto;
}

.login-error {
  color: #ff453a;
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.login-btn {
  width: 100%;
}

.login-hint {
  font-size: 22rpx;
  color: #c7c7cc;
  text-align: center;
}

/* 首页 */
.welcome-section {
  margin-bottom: 32rpx;
}

.welcome-text {
  margin-bottom: 8rpx;
}

.welcome-greeting {
  font-size: 32rpx;
  color: #86868b;
}

.welcome-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.welcome-date {
  font-size: 24rpx;
  color: #86868b;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-between;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.quick-item:active {
  opacity: 0.7;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #636366;
}

/* 最近入库 */
.recent-list {
  margin-top: -8rpx;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f7;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 4rpx;
}

.recent-desc {
  font-size: 24rpx;
  color: #86868b;
}

.recent-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #30d158;
  text-align: right;
}

.recent-unit {
  font-size: 22rpx;
  color: #86868b;
  text-align: right;
}

/* 低库存预警 */
.alert-list {
  margin-top: -8rpx;
}

.alert-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f7;
}

.alert-item:last-child {
  border-bottom: none;
}

.alert-name {
  font-size: 30rpx;
  color: #1d1d1f;
}

.alert-stock {
  font-size: 28rpx;
  font-weight: 600;
}
