<view class="container">
  <!-- 登录弹窗 -->
  <view class="login-overlay" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <view class="login-logo">🍽</view>
      <view class="login-title">食材管理平台</view>
      <view class="login-subtitle">移动客户端</view>

      <view class="login-form">
        <input class="input login-input" placeholder="用户名" value="{{username}}" bindinput="onUsernameInput" />
        <input class="input login-input" placeholder="密码" password value="{{password}}" bindinput="onPasswordInput" />
        <view class="login-error" wx:if="{{errorMsg}}">{{errorMsg}}</view>
        <button class="btn-primary login-btn" loading="{{loading}}" bindtap="handleLogin">登 录</button>
      </view>

      <view class="login-hint">连接: {{apiUrl}}</view>
    </view>
  </view>

  <!-- 首页内容 -->
  <block wx:if="{{isLoggedIn}}">
    <!-- 欢迎区域 -->
    <view class="welcome-section">
      <view class="welcome-text">
        <text class="welcome-greeting">下午好，</text>
        <text class="welcome-name">{{userInfo.real_name || userInfo.username || '管理员'}}</text>
      </view>
      <view class="welcome-date">{{today}}</view>
    </view>

    <!-- 统计卡片 -->
    <view class="stat-grid">
      <view class="stat-item">
        <view class="stat-value" style="color: #0a84ff;">{{stats.ingredients}}</view>
        <view class="stat-label">食材种类</view>
      </view>
      <view class="stat-item">
        <view class="stat-value" style="color: #30d158;">{{stats.stock}}</view>
        <view class="stat-label">库存总量</view>
      </view>
      <view class="stat-item">
        <view class="stat-value" style="color: #ff9f0a;">{{stats.suppliers}}</view>
        <view class="stat-label">供应商</view>
      </view>
      <view class="stat-item">
        <view class="stat-value" style="color: #ff453a;">{{stats.alerts}}</view>
        <view class="stat-label">低库存</view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="card">
      <view class="card-title">快捷操作</view>
      <view class="quick-actions">
        <view class="quick-item" bindtap="goToPage" data-url="/pages/stock/stock">
          <view class="quick-icon" style="background-color: #e3f2fd;">📥</view>
          <view class="quick-text">入库</view>
        </view>
        <view class="quick-item" bindtap="goToPage" data-url="/pages/stock/stock">
          <view class="quick-icon" style="background-color: #fff3e0;">📤</view>
          <view class="quick-text">出库</view>
        </view>
        <view class="quick-item" bindtap="goToPage" data-url="/pages/trace/trace">
          <view class="quick-icon" style="background-color: #f3e5f5;">🔍</view>
          <view class="quick-text">追溯</view>
        </view>
        <view class="quick-item" bindtap="goToPage" data-url="/pages/ingredients/ingredients">
          <view class="quick-icon" style="background-color: #e8f5e9;">📋</view>
          <view class="quick-text">盘点</view>
        </view>
      </view>
    </view>

    <!-- 最近入库 -->
    <view class="card">
      <view class="card-title">最近入库</view>
      <view class="recent-list">
        <view class="recent-item" wx:for="{{recentStockIn}}" wx:key="id">
          <view class="recent-left">
            <view class="recent-name">{{item.ingredient_name}}</view>
            <view class="recent-desc">{{item.supplier_name}} · {{item.created_at}}</view>
          </view>
          <view class="recent-right">
            <view class="recent-amount">+{{item.quantity}}</view>
            <view class="recent-unit">{{item.unit}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 低库存预警 -->
    <view class="card" wx:if="{{lowStock.length > 0}}">
      <view class="card-title" style="color: #ff453a;">⚠️ 低库存预警</view>
      <view class="alert-list">
        <view class="alert-item" wx:for="{{lowStock}}" wx:key="id">
          <view class="alert-name">{{item.name}}</view>
          <view class="alert-stock">
            <text style="color: #ff453a;">{{item.current_stock}}</text>
            <text style="color: #86868b;"> / {{item.safety_stock}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
