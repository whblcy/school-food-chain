.tab-bar {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  transition: all 0.3s;
}

.tab-item.active {
  background-color: #0a84ff;
}

.tab-item.active .tab-icon,
.tab-item.active .tab-text {
  color: #ffffff;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 26rpx;
  color: #636366;
}

/* 表单 */
.form-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #636366;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.picker-value {
  background-color: #f5f5f7;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #1d1d1f;
}

.picker-value.placeholder {
  color: #c7c7cc;
}

.stock-hint {
  font-size: 26rpx;
  color: #86868b;
  padding: 16rpx 0;
}

.stock-value {
  color: #0a84ff;
  font-weight: 600;
}

/* 记录列表 */
.record-list {
  margin-top: -8rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f7;
}

.record-item:last-child {
  border-bottom: none;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 4rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #86868b;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 700;
}

.text-green {
  color: #30d158;
}

.text-red {
  color: #ff453a;
}
