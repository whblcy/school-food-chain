<view class="container">
  <!-- 用户信息卡片 -->
  <view class="profile-card">
    <view class="avatar">👤</view>
    <view class="profile-info">
      <view class="profile-name">{{userInfo.real_name || userInfo.username || '未登录'}}</view>
      <view class="profile-role">{{roleText}}</view>
    </view>
    <view class="profile-org" wx:if="{{userInfo.org_name}}">{{userInfo.org_name}}</view>
  </view>

  <!-- 统计概览 -->
  <view class="stat-grid" wx:if="{{isLoggedIn}}">
    <view class="stat-item">
      <view class="stat-value" style="color: #0a84ff;">{{stats.todayIn}}</view>
      <view class="stat-label">今日入库</view>
    </view>
    <view class="stat-item">
      <view class="stat-value" style="color: #ff453a;">{{stats.todayOut}}</view>
      <view class="stat-label">今日出库</view>
    </view>
    <view class="stat-item">
      <view class="stat-value" style="color: #30d158;">{{stats.checkCount}}</view>
      <view class="stat-label">本月盘点</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="goToIngredients">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-text">食材管理</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goToStock">
      <view class="menu-left">
        <text class="menu-icon">📦</text>
        <text class="menu-text">出入库记录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goToTrace">
      <view class="menu-left">
        <text class="menu-icon">🔍</text>
        <text class="menu-text">追溯查询</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goToUsers" wx:if="{{isAdmin}}">
      <view class="menu-left">
        <text class="menu-icon">👥</text>
        <text class="menu-text">用户管理</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 系统信息 -->
  <view class="menu-card">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">版本信息</text>
      </view>
      <text class="menu-value">v2.0.0</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">🔗</text>
        <text class="menu-text">服务器地址</text>
      </view>
      <text class="menu-value">{{apiUrl}}</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="btn-danger logout-btn" wx:if="{{isLoggedIn}}" bindtap="handleLogout">退出登录</button>
</view>
