<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索食材名称..." value="{{keyword}}" bindinput="onSearch" />
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view class="category-item {{activeCategory === '' ? 'active' : ''}}" bindtap="filterCategory" data-category="">全部</view>
      <view class="category-item {{activeCategory === '蔬菜' ? 'active' : ''}}" bindtap="filterCategory" data-category="蔬菜">蔬菜</view>
      <view class="category-item {{activeCategory === '肉类' ? 'active' : ''}}" bindtap="filterCategory" data-category="肉类">肉类</view>
      <view class="category-item {{activeCategory === '粮油' ? 'active' : ''}}" bindtap="filterCategory" data-category="粮油">粮油</view>
      <view class="category-item {{activeCategory === '调味品' ? 'active' : ''}}" bindtap="filterCategory" data-category="调味品">调味品</view>
      <view class="category-item {{activeCategory === '蛋奶' ? 'active' : ''}}" bindtap="filterCategory" data-category="蛋奶">蛋奶</view>
      <view class="category-item {{activeCategory === '水产' ? 'active' : ''}}" bindtap="filterCategory" data-category="水产">水产</view>
    </view>
  </scroll-view>

  <!-- 食材列表 -->
  <view class="ingredient-list">
    <view class="ingredient-card" wx:for="{{ingredients}}" wx:key="id" bindtap="showDetail" data-item="{{item}}">
      <view class="ingredient-header">
        <view class="ingredient-name">{{item.name}}</view>
        <view class="tag {{item.status === '正常' ? 'tag-green' : (item.status === '偏低' ? 'tag-yellow' : 'tag-red')}}">{{item.status}}</view>
      </view>
      <view class="ingredient-info">
        <view class="info-item">
          <text class="info-label">编码</text>
          <text class="info-value">{{item.code}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">品类</text>
          <text class="info-value">{{item.category}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">库存</text>
          <text class="info-value {{item.current_stock <= item.safety_stock ? 'text-red' : 'text-green'}}">{{item.current_stock}} {{item.unit}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">安全库存</text>
          <text class="info-value">{{item.safety_stock}} {{item.unit}}</text>
        </view>
      </view>
      <view class="ingredient-progress">
        <view class="progress-bar">
          <view class="progress-fill {{item.progress <= 30 ? 'progress-red' : (item.progress <= 60 ? 'progress-yellow' : 'progress-green')}}" style="width: {{item.progress}}%"></view>
        </view>
        <text class="progress-text">{{item.progress}}%</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{ingredients.length === 0}}">
    <view class="empty-icon">📦</view>
    <view class="empty-text">暂无食材数据</view>
  </view>

  <!-- 详情弹窗 -->
  <view class="modal" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-header">
        <view class="modal-title">{{selectedItem.name}}</view>
        <view class="modal-close" bindtap="closeModal">✕</view>
      </view>
      <view class="modal-body">
        <view class="detail-row">
          <text class="detail-label">编码</text>
          <text class="detail-value">{{selectedItem.code}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">品类</text>
          <text class="detail-value">{{selectedItem.category}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">当前库存</text>
          <text class="detail-value {{selectedItem.current_stock <= selectedItem.safety_stock ? 'text-red' : ''}}">{{selectedItem.current_stock}} {{selectedItem.unit}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">安全库存</text>
          <text class="detail-value">{{selectedItem.safety_stock}} {{selectedItem.unit}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">规格</text>
          <text class="detail-value">{{selectedItem.specification || '-'}}</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-default" bindtap="closeModal">关闭</button>
      </view>
    </view>
  </view>
</view>
