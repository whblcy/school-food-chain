/* ===== 全局样式 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans SC", sans-serif;
  font-size: 28rpx;
  color: #1d1d1f;
  background-color: #f5f5f7;
  line-height: 1.5;
}

/* ===== 容器 ===== */
.container {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

/* ===== 统计卡片 ===== */
.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  min-width: 160rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0a84ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #86868b;
}

/* ===== 按钮 ===== */
.btn-primary {
  background-color: #0a84ff;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  background-color: #0071e3;
}

.btn-danger {
  background-color: #ff453a;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: none;
}

.btn-danger::after {
  border: none;
}

.btn-default {
  background-color: #ffffff;
  color: #1d1d1f;
  border: 2rpx solid #d1d1d6;
  border-radius: 16rpx;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
}

.btn-default::after {
  border: none;
}

/* ===== 输入框 ===== */
.input {
  background-color: #f5f5f7;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #1d1d1f;
  border: 2rpx solid transparent;
}

.input:focus {
  border-color: #0a84ff;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-green {
  background-color: #e8f5e9;
  color: #30d158;
}

.tag-red {
  background-color: #ffebee;
  color: #ff453a;
}

.tag-yellow {
  background-color: #fff8e1;
  color: #ff9f0a;
}

.tag-blue {
  background-color: #e3f2fd;
  color: #0a84ff;
}

.tag-gray {
  background-color: #f5f5f5;
  color: #86868b;
}

/* ===== 列表项 ===== */
.list-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.list-item:active {
  background-color: #f5f5f7;
}

.list-item-left {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 24rpx;
  color: #86868b;
}

.list-item-right {
  text-align: right;
}

.list-item-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}

/* ===== 搜索框 ===== */
.search-bar {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #86868b;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1d1d1f;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #86868b;
}

/* ===== 分割线 ===== */
.divider {
  height: 2rpx;
  background-color: #e5e5ea;
  margin: 24rpx 0;
}

/* ===== 安全区域 ===== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
