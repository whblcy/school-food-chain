# ============================================================
# 学校食材供应链平台 — Docker Compose 环境变量示例
# 使用方法: 复制为 .env 然后按需修改
# ============================================================

# ---- 应用环境 ----
# development / staging / production
# 生产环境会强制校验 SECRET_KEY / DEBUG / CORS_ORIGINS
ENVIRONMENT=development

# ---- 后端安全 ----
SECRET_KEY=please-change-this-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
# refresh_token 有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- JWT 签名算法 ----
# HS256: 对称密钥（开发环境默认，使用 SECRET_KEY）
# RS256: RSA 非对称密钥（生产环境强制，公钥可分发给微服务验证）
JWT_ALGORITHM=HS256
# RS256 模式下的私钥/公钥（PEM 格式，多行用 \n 转义）
# 生成命令: openssl genrsa -out private.pem 2048
#          openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# 或通过文件路径加载（推荐，避免环境变量转义问题）
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=

# ---- HttpOnly Cookie ----
# 启用后登录/刷新接口会同时设置 Cookie（防 XSS 窃取 token）
COOKIE_ENABLED=true
# 生产环境必须为 true（仅 HTTPS 传输）
COOKIE_SECURE=false
# same-site 策略: strict / lax / none
COOKIE_SAMESITE=lax
# Cookie 域名（留空则不设置，跨子域共享时配置如 .example.com）
COOKIE_DOMAIN=

# ---- CORS 允许来源 ----
# 逗号分隔，生产环境必须改为具体域名，不能使用 *
# 示例: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=school_food

# ---- Redis ----
# 默认使用 docker-compose 服务名 redis，无需修改

# ---- MinIO ----
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=school-food

# ---- 前端暴露端口 ----
WEB_PORT=8080
