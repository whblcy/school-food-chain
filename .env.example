# =============================================================================
# School Food Chain - 环境变量配置模板
# 复制此文件为 .env 并修改对应值：cp .env.example .env
# =============================================================================

# ---------- 应用配置 ----------
APP_NAME=School Food Chain
DEBUG=false

# ---------- 安全配置 ----------
# JWT 签名密钥（生产环境务必修改为随机强密钥）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# Token 过期时间
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 允许的来源（多个以逗号分隔，生产环境请限制具体域名）
CORS_ORIGINS=*

# ---------- 数据库 ----------
# PostgreSQL 连接字符串
# Docker 环境：host 使用服务名 postgres
# 手动部署：host 使用 localhost 或 127.0.0.1
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/school_food

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- MinIO 文件存储 ----------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=school-food

# ---------- 分页配置 ----------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ---------- Docker Compose 专用 ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=school_food
